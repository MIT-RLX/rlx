# Copy to scripts/rig/local.env (gitignored) to override rig defaults.
#
# RIG_HOST=user@100.103.104.54
# SSH_KEY=$HOME/.ssh/utm_windows
# RIG_RUNTIME=windows    # windows | wsl | both
# RIG_WORKSPACE_WIN=D:/rlx-workspace
# RIG_ROOT_WIN=D:/rlx-workspace/rlx
# RIG_BUILD_WIN=C:/Users/user/AppData/Local/rlx-workspace/rlx
# RIG_TARGET_WIN=C:/Users/user/AppData/Local/rlx-cargo-target
# RIG_OPENBLAS_DIR=C:/OpenBLAS
# RIG_CARGO_WIN=C:/Users/user/.rustup/toolchains/stable-x86_64-pc-windows-msvc/bin/cargo.exe
# RIG_TOOLCHAIN_BIN_WIN=C:/Users/user/.rustup/toolchains/stable-x86_64-pc-windows-msvc/bin
# RIG_WSL_DISTRO=Ubuntu
# RIG_ROOT_WSL=/mnt/d/rlx-workspace/rlx
